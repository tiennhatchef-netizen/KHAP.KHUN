# ====== CẤU HÌNH DATABASE (BẮT BUỘC) ======
# Thay user, password, host, port, dbname bằng thông tin Postgres thực tế của bạn.
# Nếu chạy Postgres local mặc định sau khi tạo database "khapkhun":
DATABASE_URL=postgres://postgres:postgres@localhost:5432/khapkhun

# ====== BẢO MẬT ======
# Đổi thành một chuỗi ngẫu nhiên, bí mật, dùng để ký JWT token đăng nhập
JWT_SECRET=doi-secret-nay-thanh-chuoi-bi-mat-cua-ban

# ====== TÀI KHOẢN SUPERADMIN TẠO LẦN ĐẦU ======
# Chỉ áp dụng khi database chưa có user nào (lần khởi tạo đầu tiên)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# ====== CỔNG CHẠY SERVER ======
PORT=3000
